    <entry>
      <title type="html">GIT 기본문법</title>
      <link href="https://intoreal.github.io/GIT" rel="alternate" type="text/html" title="GIT 기본문법" />
      <published>2021-05-01T19:13:00+00:00</published>
      <updated>2021-05-01T19:13:00+00:00</updated>
      <id>https://intoreal.github.io/GIT</id>
      <content type="html" xml:base="https://intoreal.github.io/GIT">&lt;h2 id=&quot;git-설치-및-설정&quot;&gt;Git 설치 및 설정&lt;/h2&gt;

&lt;ul&gt;
  &lt;li&gt;
    &lt;p&gt;초기화&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;&lt;span class=&quot;c&quot;&gt;# git 초기화시&lt;/span&gt;
git init
&lt;span class=&quot;c&quot;&gt;# git 삭제시&lt;/span&gt;
&lt;span class=&quot;nb&quot;&gt;rm&lt;/span&gt; &lt;span class=&quot;nt&quot;&gt;-rf&lt;/span&gt; .git
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;현재 설정 확인&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;&lt;span class=&quot;c&quot;&gt;# 전체 설정 확인&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--list&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# 항목별 설정 확인&lt;/span&gt;
git config user.name
git config user.email
git config core.editor
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;현재 설정을 에디터에서 수정&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; &lt;span class=&quot;nt&quot;&gt;-e&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;

    &lt;ul&gt;
      &lt;li&gt;
        &lt;p&gt;에디터 확인&lt;/p&gt;

        &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;code &lt;span class=&quot;nb&quot;&gt;.&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;        &lt;/div&gt;
      &lt;/li&gt;
    &lt;/ul&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;기본 에디터 변경&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;&lt;span class=&quot;c&quot;&gt;# 동시 편집 가능&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; core.editor &lt;span class=&quot;s2&quot;&gt;&quot;code&quot;&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# 에디터 종료 대기&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; core.editor &lt;span class=&quot;s2&quot;&gt;&quot;code --wait&quot;&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;사용자 정보 변경&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; user.name &lt;span class=&quot;s2&quot;&gt;&quot;jihwan&quot;&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; user.email &lt;span class=&quot;s2&quot;&gt;&quot;my@name.com&quot;&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;라인 Endian  설정&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;&lt;span class=&quot;c&quot;&gt;# 윈도우 사용자&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; core.autocrlf &lt;span class=&quot;nb&quot;&gt;true&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# 맥 사용자&lt;/span&gt;
git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; core.autocrlf input
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;축약어 설정&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git config &lt;span class=&quot;nt&quot;&gt;--global&lt;/span&gt; alias.&amp;lt;축약어, 예시: st&amp;gt; &amp;lt;명령어, 예시: status&amp;gt;
&lt;span class=&quot;c&quot;&gt;# 사용법&lt;/span&gt;
git st
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;h2 id=&quot;수정-및-복구&quot;&gt;수정 및 복구&lt;/h2&gt;

&lt;ul&gt;
  &lt;li&gt;
    &lt;p&gt;수정 및 복구&lt;/p&gt;

    &lt;p&gt;&lt;img src=&quot;\assets\images\contents-images\2021-05-01-GIT-git_restore.png&quot; alt=&quot;git_restore&quot; /&gt;&lt;/p&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;예전 파일 복구하기&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git restore &amp;lt;filename&amp;gt; &lt;span class=&quot;c&quot;&gt;# staged 파일 이상의 내용으로 working directory를 복구한다. &lt;/span&gt;
git restore &lt;span class=&quot;nt&quot;&gt;-s&lt;/span&gt; HEAD &amp;lt;filename&amp;gt; &lt;span class=&quot;c&quot;&gt;# 가장 최근 커밋되었던 내용으로 복구한다. &lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;예전 커밋 파일 가져오기(현재 파일로)&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git checkout &amp;lt;커밋 sha값 or branch 이름&amp;gt; &amp;lt;파일명&amp;gt; &lt;span class=&quot;c&quot;&gt;# 현재 파일을 과거 커밋의 파일로 교체한다.(스테이징도 한다.) &lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;예전 커밋 파일 가져오기(다른 파일로)&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git checkout &amp;lt;과거 커밋 sha or branch 이름&amp;gt; &lt;span class=&quot;c&quot;&gt;# 과거 상태를 확인하는 상태로 전환&lt;/span&gt;
&lt;span class=&quot;nb&quot;&gt;cp&lt;/span&gt; &amp;lt;target file&amp;gt; &amp;lt;backup file&amp;gt; &lt;span class=&quot;c&quot;&gt;# 가져오기 원하는 파일의 백업본 생성&lt;/span&gt;
git checkout HEAD &lt;span class=&quot;c&quot;&gt;# 원래 브랜치 위치로 복귀&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# untracked 상태의 파일로 원하는 작업 수행&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;파일 삭제하기&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git &lt;span class=&quot;nb&quot;&gt;rm&lt;/span&gt; &amp;lt;파일명&amp;gt; &lt;span class=&quot;c&quot;&gt;# 워킹 디렉토리에서 삭제, 로컬/원격에서도 삭제&lt;/span&gt;
git &lt;span class=&quot;nb&quot;&gt;rm&lt;/span&gt; &lt;span class=&quot;nt&quot;&gt;--cached&lt;/span&gt; &amp;lt;파일명&amp;gt; &lt;span class=&quot;c&quot;&gt;# 워킹 디렉토리에는 남김(untracked), 로컬/원격 저장소에서만 삭제&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;h2 id=&quot;커밋-관리&quot;&gt;커밋 관리&lt;/h2&gt;

&lt;ul&gt;
  &lt;li&gt;
    &lt;p&gt;과거 커밋 지점 확인&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git reflog &lt;span class=&quot;c&quot;&gt;# HEAD가 그간 표시하였던 커밋지점 표기(SHA값), log에서 안보이는 커밋도 확인 가능&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;커밋 통합&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git rebase &lt;span class=&quot;nt&quot;&gt;-i&lt;/span&gt; HEAD~3 &lt;span class=&quot;c&quot;&gt;# master branch에 merge하기 전 정리용, HEAD이전 3개의 커밋을 통합한다.&lt;/span&gt;
  
&lt;span class=&quot;c&quot;&gt;# 1단계: interactive 창에서 가장 오래된 커밋을 pick으로 나머지 커밋을 s로 변경하여 통합&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# 2단계: 가장 위에 통합 커밋 메시지를 적는다. &lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;h2 id=&quot;branch-관리&quot;&gt;branch 관리&lt;/h2&gt;

&lt;ul&gt;
  &lt;li&gt;branch 생성
    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git branch &amp;lt;새로운 branch명&amp;gt; &lt;span class=&quot;c&quot;&gt;# 브랜치를 생성만 할 때&lt;/span&gt;
git checkout &lt;span class=&quot;nt&quot;&gt;-b&lt;/span&gt; &amp;lt;새로운 branch명&amp;gt; &lt;span class=&quot;c&quot;&gt;# 브랜치를 생성하고 동시에 이동&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;branch 확인
    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git branch
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;branch 이동
    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git checkout &amp;lt;다른 branch명&amp;gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;h2 id=&quot;원격-저장소-관리&quot;&gt;원격 저장소 관리&lt;/h2&gt;

&lt;ul&gt;
  &lt;li&gt;
    &lt;p&gt;원격저장소 현황 확인&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git remote &lt;span class=&quot;nt&quot;&gt;-v&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;원격저장소 등록&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git remote add origin &amp;lt;원격 저장소 주소&amp;gt; &lt;span class=&quot;c&quot;&gt;# 주소 등록&lt;/span&gt;
git fetch  &lt;span class=&quot;c&quot;&gt;# 원격 저장소 내용 확인&lt;/span&gt;
&lt;span class=&quot;c&quot;&gt;# 현 브랜치에서 최소 1개의 커밋을 실행한 후&lt;/span&gt;
  
git branch &lt;span class=&quot;nt&quot;&gt;--set-upstream-to&lt;/span&gt;&lt;span class=&quot;o&quot;&gt;=&lt;/span&gt;origin/main master &lt;span class=&quot;c&quot;&gt;# 원격 main 브랜치와 로컬 master 브랜치 연결&lt;/span&gt;
git pull &lt;span class=&quot;nt&quot;&gt;--allow-unrelated-histories&lt;/span&gt; &lt;span class=&quot;c&quot;&gt;# 원격 저장소 내용 적용(그간 연관성이 없더라도 실행 허용)&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;p&gt;원격저장소 해제&lt;/p&gt;

    &lt;div class=&quot;language-sh highlighter-rouge&quot;&gt;&lt;div class=&quot;highlight&quot;&gt;&lt;pre class=&quot;highlight&quot;&gt;&lt;code&gt;git remote &lt;span class=&quot;nb&quot;&gt;rm &lt;/span&gt;origin &lt;span class=&quot;c&quot;&gt;# 원격 저장소 등록 해제&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;    &lt;/div&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;h2 id=&quot;그-외-기타&quot;&gt;그 외 기타&lt;/h2&gt;

&lt;h3 id=&quot;conflict-해결&quot;&gt;Conflict 해결&lt;/h3&gt;
&lt;ul&gt;
  &lt;li&gt;Conflict가 있을 경우 git push는 진행되지 않는다.&lt;/li&gt;
  &lt;li&gt;
    &lt;table&gt;
      &lt;tbody&gt;
        &lt;tr&gt;
          &lt;td&gt;Conflict가 있을 경우 git pull시 master&lt;/td&gt;
          &lt;td&gt;merge상태로 변경된다.&lt;/td&gt;
        &lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;
    &lt;ul&gt;
      &lt;li&gt;이때 텍스트 파일은 충돌한 내용이 반영되어 변경되며&lt;/li&gt;
      &lt;li&gt;바이너리 파일은 변경내용이 반영되지 않는다.&lt;/li&gt;
    &lt;/ul&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;table&gt;
      &lt;tbody&gt;
        &lt;tr&gt;
          &lt;td&gt;master&lt;/td&gt;
          &lt;td&gt;merge상태에서 git diff를 통해 Staging되지 않은 변경된 내용을 확인할 수 있다.&lt;/td&gt;
        &lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;table&gt;
      &lt;tbody&gt;
        &lt;tr&gt;
          &lt;td&gt;master&lt;/td&gt;
          &lt;td&gt;merge상태에서 git reset head를 할 경우 merge 상태가 취소되나 수정된 파일들은 변경된 채로 남는다.&lt;/td&gt;
        &lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;
  &lt;/li&gt;
  &lt;li&gt;
    &lt;table&gt;
      &lt;tbody&gt;
        &lt;tr&gt;
          &lt;td&gt;master&lt;/td&gt;
          &lt;td&gt;merge상태에서 충돌내용을 적절히 반영하여 처리하여야 한다. &lt;br /&gt;그 뒤 git add, git commit을 통해 Conflict를 해소하고 다시 git push하면 수정한 현재 파일이 원격저장소에 반영된다.&lt;/td&gt;
        &lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;
  &lt;/li&gt;
  &lt;li&gt;충돌이 날 경우 일단 git fetch 후 git checkout origin/master로 가서 내용을 확인하자.&lt;/li&gt;
&lt;/ul&gt;

&lt;h3 id=&quot;staging-해제&quot;&gt;Staging 해제&lt;/h3&gt;
&lt;ul&gt;
